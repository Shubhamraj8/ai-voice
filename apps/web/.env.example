# Copy to apps/web/.env.local for local dev.
# Set the same NEXT_PUBLIC_* vars in Vercel → Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local API (Render in production — see docs/deploy-vercel.md)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site origin for SEO metadata (og:url, canonical). Falls back to
# http://localhost:3000 if unset — set it to the real apex on Vercel so social
# previews and canonical URLs don't point at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production subdomain routing (optional locally — use path routes on localhost:3000)
# NEXT_PUBLIC_APP_DOMAIN=yourdomain.ai
# NEXT_PUBLIC_PORTAL_HOST=app.yourdomain.ai
# NEXT_PUBLIC_INTERNAL_HOST=internal.yourdomain.ai

# Sentry frontend (ticket 5.16). Optional: the SDK no-ops without a DSN.
# Runtime (set in Vercel → Environment Variables for prod):
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXX.ingest.sentry.io/XXXX
# SENTRY_DSN=https://your-key@oXXXX.ingest.sentry.io/XXXX
# Build-time only — source-map upload (set in Vercel + CI secrets, NOT public):
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_...
