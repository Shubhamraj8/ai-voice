{
  "name": "@ai-voice/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "install:python": "python -m pip install -r requirements-dev.txt",
    "lint": "python -m ruff check app",
    "format": "python -m black app",
    "format:check": "python -m black --check app",
    "test": "python -m pytest tests/ -q"
  }
}
