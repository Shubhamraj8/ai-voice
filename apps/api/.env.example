# Copy to repo root .env for local dev, or set in Render Dashboard for production.

DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated browser origins (local + Vercel production/preview)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

LOG_LEVEL=INFO

# Twilio webhooks (ticket 2.02) — set TWILIO_AUTH_TOKEN after 2.01
TWILIO_AUTH_TOKEN=
PUBLIC_API_BASE_URL=http://localhost:8000
# TWILIO_MEDIA_STREAM_PATH=/webhooks/twilio/media
# TWILIO_SIGNATURE_VALIDATION=false

# Internal dashboard (ticket 3.01) — founding staff auto-promoted on first login
INTERNAL_USER_EMAIL=you@yourcompany.com
