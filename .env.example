# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js public env vars (exposed to browser) — mirrors the values above
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FastAPI base URL for client-side and server-side API calls (e.g. GET /me)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production subdomain routing (Vercel — ticket 1.18, see docs/deploy-vercel.md)
# NEXT_PUBLIC_APP_DOMAIN=yourdomain.ai
# NEXT_PUBLIC_PORTAL_HOST=app.yourdomain.ai
# NEXT_PUBLIC_INTERNAL_HOST=internal.yourdomain.ai

# Postgres — Project Settings → Database → Connection string (URI)
# Use "Direct connection" for local migrations (not the transaction pooler on port 6543).
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# API — comma-separated browser origins (local + Vercel preview/production)
CORS_ORIGINS=http://localhost:3000

# Production API URL (Render) — see docs/deploy-render.md
# NEXT_PUBLIC_API_URL=https://ai-voice-api.onrender.com

# Twilio — credentials from twilio.com/console (ticket 2.01)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ngrok dev tunnel (ticket 2.03) — winget install ngrok.ngrok
# Get your authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# Voice testing (one command, finds ngrok automatically):
#   pnpm dev:voice
#   OR: .\scripts\dev-with-tunnel.ps1
# Paid plan only — gives a stable URL so you don't update Twilio on every restart:
# NGROK_SUBDOMAIN=your-stable-subdomain
# Set to true to auto-update the Twilio Voice URL when the tunnel starts:
# TWILIO_AUTO_UPDATE_WEBHOOK=false

# FastAPI public URL — updated to the ngrok URL during dev, Render URL in prod
# PUBLIC_API_BASE_URL=http://localhost:8000
# PUBLIC_API_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
# PUBLIC_API_BASE_URL=https://ai-voice-ocy9.onrender.com

# Deepgram — console.deepgram.com (ticket 2.05)
# Free tier works for dev. Without this key the pipeline plays a hello tone only.
# DEEPGRAM_API_KEY=your_deepgram_api_key
# DEEPGRAM_VOICE=aura-2-helena-en

# Internal dashboard (API — ticket 3.01)
# INTERNAL_USER_EMAIL=you@yourcompany.com

# Deepgram — Aura-1 TTS + Nova-3 STT (ticket 2.07)
# Get your key from https://console.deepgram.com → Projects → API Keys
# DEEPGRAM_API_KEY=your_deepgram_api_key

# DeepSeek — V4 Flash LLM (ticket 2.09)
# Get your key from https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI embeddings — RAG ingestion + query retrieval (tickets 4.03, 4.05)
# Get your key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Upstash Redis (REST) — query-embedding cache + tool rate limits (4.05, 4.12)
# Create a database at https://console.upstash.com → copy the REST URL + token.
# Optional: without it, query embeddings are simply recomputed each time.
# UPSTASH_REDIS_URL=https://your-db.upstash.io
# UPSTASH_REDIS_TOKEN=your_upstash_rest_token

# Escalation email — Resend (ticket 4.10). Owner notifications via escalateToOwner.
# Get a key at https://resend.com → API Keys; FROM must be a verified sender.
# Optional: without it, escalation emails are skipped (SMS/log still happen).
# RESEND_API_KEY=re_...
# ESCALATION_FROM_EMAIL=alerts@yourdomain.com
# Portal base URL used to build call-detail links in escalation emails (Phase 5).
# PUBLIC_APP_BASE_URL=http://localhost:3000

# Lead capture (ticket 5.02) — where new landing-page leads are emailed.
# Optional: without it, leads are still stored + shown in the internal inbox.
# LEADS_NOTIFY_EMAIL=onboarding@yourdomain.com

# DPDP data export (ticket 5.12) — Supabase Storage bucket for export ZIPs.
# Create a PRIVATE bucket named "exports" (like recordings/knowledge).
# EXPORTS_BUCKET=exports

# Error monitoring — Sentry backend (ticket 5.17). Optional: no-op without a DSN.
# SENTRY_DSN=https://your-key@oXXXX.ingest.sentry.io/XXXX
# SENTRY_ENVIRONMENT=production
# RENDER_GIT_COMMIT is injected automatically by Render — do not set manually.

# PII scrubbing (ticket 5.18) — allowlisted staff domains + known names kept/redacted.
# PII_ALLOWED_EMAIL_DOMAINS=zerqo.com
# PII_KNOWN_NAMES=
