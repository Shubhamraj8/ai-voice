# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js public env vars (exposed to browser) — mirrors the values above
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FastAPI base URL for client-side and server-side API calls (e.g. GET /me)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production subdomain routing (Vercel — ticket 1.18, see docs/deploy-vercel.md)
# NEXT_PUBLIC_APP_DOMAIN=yourdomain.ai
# NEXT_PUBLIC_PORTAL_HOST=app.yourdomain.ai
# NEXT_PUBLIC_INTERNAL_HOST=internal.yourdomain.ai

# Postgres — Project Settings → Database → Connection string (URI)
# Use "Direct connection" for local migrations (not the transaction pooler on port 6543).
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# API — comma-separated browser origins (local + Vercel preview/production)
CORS_ORIGINS=http://localhost:3000

# Production API URL (Render) — see docs/deploy-render.md
# NEXT_PUBLIC_API_URL=https://ai-voice-api.onrender.com

# Twilio — credentials from twilio.com/console (ticket 2.01)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ngrok dev tunnel (ticket 2.03) — https://ngrok.com/download
# Get your authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# Paid plan only — gives a stable URL so you don't update Twilio on every restart:
# NGROK_SUBDOMAIN=your-stable-subdomain
# Set to true to auto-update the Twilio Voice URL when the tunnel starts:
# TWILIO_AUTO_UPDATE_WEBHOOK=false

# FastAPI public URL — updated to the ngrok URL during dev, Render URL in prod
# PUBLIC_API_BASE_URL=http://localhost:8000
# PUBLIC_API_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
# PUBLIC_API_BASE_URL=https://ai-voice-ocy9.onrender.com

# Internal dashboard (API — ticket 3.01)
# INTERNAL_USER_EMAIL=you@yourcompany.com
